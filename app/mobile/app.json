{
  "expo": {
    "name": "Loan Manager Mobile",
    "slug": "loan-manager-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fieldops",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#091E42"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.loanmanager.mobile",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#091E42"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "asyncRoutes": {
            "web": "production"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "default",
          "color": "#5305C7"
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9581509f-04c2-4e7f-a268-1a5abfd6e4af"
      }
    },
    "owner": "ernestoruiz89"
  }
}
